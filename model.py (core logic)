import pandas as pd
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity

# Load dataset
df = pd.read_csv("data/courses.csv")

# Combine text features
df["content"] = df["name"] + " " + df["description"]

# Vectorize
vectorizer = TfidfVectorizer(stop_words="english")
tfidf_matrix = vectorizer.fit_transform(df["content"])

def recommend_courses(user_input, top_n=3):
    user_vec = vectorizer.transform([user_input])
    similarity = cosine_similarity(user_vec, tfidf_matrix).flatten()
    indices = similarity.argsort()[-top_n:][::-1]
    
    return df.iloc[indices][["name", "description"]]
